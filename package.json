{
  "name": "@aoguai/subscription",
  "version": "1.23.0",
  "type": "module",
  "gkd": {
    "outDir": "dist",
    "file": "aoguai_gkd.json5",
    "versionFile": "aoguai_gkd.version.json5",
    "changelog": "CHANGELOG.md",
    "README.md": "README.md"
  },
  "scripts": {
    "postinstall": "simple-git-hooks",
    "format": "prettier --cache --write ./**/*.{js,cjs,mjs,ts,jsx,tsx,json}",
    "lint": "eslint --cache --fix ./**/*.{js,cjs,mjs,ts,jsx,tsx}",
    "check": "tsc --noEmit && tsx ./scripts/check.ts",
    "build": "tsc --noEmit && tsx ./scripts/build.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "pre-push": "pnpm run check"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts,jsx,tsx}": [
      "prettier --cache --write",
      "eslint --cache --fix"
    ],
    "*.json": [
      "prettier --cache --write"
    ]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "./dist"
  ],
  "dependencies": {
    "@eslint/js": "9.30.1",
    "@gkd-kit/api": "0.7.3",
    "@gkd-kit/define": "0.0.1",
    "@gkd-kit/tools": "0.6.0",
    "@types/node": "22.15.34",
    "eslint": "9.30.1",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-unused-imports": "4.1.4",
    "json5": "2.2.3",
    "lint-staged": "16.1.2",
    "prettier": "3.6.2",
    "simple-git-hooks": "2.13.0",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.1"
  },
  "volta": {
    "node": "22.17.0",
    "pnpm": "10.12.4"
  },
  "packageManager": "pnpm@10.12.4",
  "engineStrict": true,
  "engines": {
    "node": ">=22"
  }
}
